      <svg class="w-7 h-7" viewBox="0 0 128 128" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="64" cy="36" r="8" fill="#b8860b" class="group-hover:fill-[#d4a853] transition-colors"/>
        <circle cx="36" cy="64" r="6" fill="#b8860b" class="group-hover:fill-[#d4a853] transition-colors"/>
        <circle cx="92" cy="64" r="6" fill="#b8860b" class="group-hover:fill-[#d4a853] transition-colors"/>
        <circle cx="50" cy="92" r="5" fill="#b8860b" class="group-hover:fill-[#d4a853] transition-colors"/>
        <circle cx="78" cy="92" r="5" fill="#b8860b" class="group-hover:fill-[#d4a853] transition-colors"/>
