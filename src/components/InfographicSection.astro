---
interface Props {
  infographics: Array<{ id: string; title: string }>;
}

const { infographics } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="mt-20 pt-10 border-t border-gold-pale/60">
  <div class="flex items-center gap-3 mb-8">
    <div class="w-1 h-6 bg-gold rounded-full"></div>
    <h2 class="text-sm font-mono font-medium tracking-widest text-ink-muted uppercase">信息图</h2>
  </div>
  <div class="space-y-10">
    {infographics.map((info) => (
      <figure class="rounded-xl overflow-hidden border border-gold-pale/60 shadow-sm">
        <img
          src={`${base}/infographic/${info.id}/infographic.png`}
          alt={info.title}
          loading="lazy"
          class="w-full"
          onerror={`this.parentElement.innerHTML='<div class=\\'flex items-center justify-center h-48 bg-paper-warm text-ink-muted/30 text-sm font-sans\\'>信息图即将推出</div>'`}
        />
        <figcaption class="px-5 py-3 text-sm text-ink-muted border-t border-gold-pale/40 bg-paper-warm/30">
          {info.title}
        </figcaption>
      </figure>
    ))}
  </div>
</section>