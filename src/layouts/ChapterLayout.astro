---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Prose from '../components/Prose.astro';
import PdfDownload from '../components/PdfDownload.astro';
import SocialLinks from '../components/SocialLinks.astro';
import ChapterNav from '../components/ChapterNav.astro';

interface Props {
  title: string;
  chapter: number;
  section: string;
  description: string;
  slides: Array<{ id: string; title: string }>;
  bilibili?: string;
  xhs?: string;
  prev?: { id: string; title: string; chapter: number } | null;
  next?: { id: string; title: string; chapter: number } | null;
}

const { title, chapter, section, description, slides, bilibili, xhs, prev, next } = Astro.props;

const sectionColors: Record<string, string> = {
  '认知篇': 'bg-ink text-white',
  '核心篇': 'bg-gold text-white',
  '进阶篇': 'bg-accent text-white',
  '实战篇': 'bg-ink-light text-white',
};
const tagClass = sectionColors[section] || 'bg-ink text-white';
---

<BaseLayout title={`第 ${chapter} 章：${title} — Deep Agents 实战`} description={description}>
  <Header />
  <article class="max-w-3xl mx-auto px-6 py-16">
    <header class="mb-14 relative">
      <div class="flex items-center gap-3 mb-6">
        <span class={`inline-block text-[10px] font-mono font-medium tracking-wider px-2.5 py-1 rounded ${tagClass}`}>
          {section}
        </span>
        <span class="text-xs text-ink-muted/40 font-mono">EP.{String(chapter).padStart(2, '0')}</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-black font-sans tracking-tight leading-tight text-ink">
        {title}
      </h1>
      <div class="mt-6 w-16 h-1 bg-gold rounded-full"></div>
    </header>

    <Prose>
      <slot />
    </Prose>

    {slides.length > 0 && (
      <PdfDownload slides={slides} />
    )}

    <SocialLinks bilibili={bilibili} xhs={xhs} />

    <ChapterNav prev={prev} next={next} />
  </article>

  <!-- Back to top button -->
  <button
    id="back-to-top"
    class="fixed bottom-8 right-8 p-3 bg-white border border-gold-pale/80 rounded-full shadow-lg opacity-0 invisible transition-all duration-300 hover:border-gold hover:shadow-xl z-50"
    aria-label="回到顶部"
  >
    <svg class="w-5 h-5 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
    </svg>
  </button>

  <script>
    const backToTop = document.getElementById('back-to-top');
    const toggleVisibility = () => {
      if (window.scrollY > 300) {
        backToTop?.classList.remove('opacity-0', 'invisible');
        backToTop?.classList.add('opacity-100', 'visible');
      } else {
        backToTop?.classList.add('opacity-0', 'invisible');
        backToTop?.classList.remove('opacity-100', 'visible');
      }
    };
    window.addEventListener('scroll', toggleVisibility, { passive: true });
    backToTop?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  </script>

  <Footer />
</BaseLayout>